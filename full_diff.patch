+            "SELECT EXISTS(SELECT 1 FROM urls WHERE id = $1 AND date_added >= $2)"
+        )
+        .bind(id)
+        .bind(cutoff_date)
+        .fetch_one(&self.pool)
+        .await?;
+
+        Ok(should_refresh)
+    }
